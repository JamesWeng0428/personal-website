---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3rem 1rem;
			}
			.hero {
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 0.5rem;
			}
			.hero .subtitle {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				margin: 0 0 1.5rem;
			}
			.hero p {
				font-size: 1rem;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
			}
			.links {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				margin-top: 1.5rem;
			}
			.links a {
				padding: 0.5rem 1rem;
				border: 1px solid rgb(var(--accent));
				border-radius: 6px;
				color: rgb(var(--accent));
				text-decoration: none;
				font-size: 0.9rem;
				transition: background 0.2s, color 0.2s;
			}
			.links a:hover {
				background: rgb(var(--accent));
				color: white;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>James Weng</h1>
				<p class="subtitle">CS + Education @ UIUC &nbsp;·&nbsp; Builder &nbsp;·&nbsp; Problem Solver</p>
				<p>
					I am currently a sophomore majoring CS+EDU (Learning Science) at the University of Illinois
					at Urbana-Champaign, graduating in December 2026/May 2027. I was originally from Shenzhen,
					China, and spent 18 years in this fast-growing city. Right now, college life provides me a
					chance to experience more.
				</p>
				<div class="links">
					<a href="/portfolio">Projects</a>
					<a href="/about">About</a>
					<a href="/blog">Blog</a>
					<a href="https://github.com/JamesWeng0428" target="_blank" rel="noopener">GitHub</a>
					<a href="https://www.linkedin.com/in/JamesWeng0428" target="_blank" rel="noopener">LinkedIn</a>
				</div>
			</div>

		</main>
		<Footer />
	</body>
</html>
