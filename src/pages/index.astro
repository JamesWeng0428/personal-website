---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3rem 1rem;
			}
			.hero {
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 0.25rem;
			}
			.hero .subtitle {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				margin: 0 0 1.5rem;
			}
			.hero-body {
				display: flex;
				gap: 2.5rem;
				align-items: flex-start;
			}
			.hero-body p {
				font-size: 1rem;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
				margin: 0;
				flex: 1;
			}
			.avatar {
				width: 200px;
				height: 200px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.currently {
				margin-top: 2.5rem;
			}
			.currently h2 {
				font-size: 1.2rem;
				margin: 0 0 0.75rem;
				color: rgb(var(--gray-dark));
				padding-bottom: 0.75rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.currently ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.currently ul li {
				font-size: 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
			}
			.currently ul li::before {
				content: "→ ";
				color: rgb(var(--accent));
			}
			@media (max-width: 560px) {
				.hero-body {
					flex-direction: column-reverse;
				}
				.avatar {
					width: 120px;
					height: 120px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>James Weng</h1>
				<p class="subtitle">CS + Education @ UIUC &nbsp;·&nbsp; ENTJ &nbsp;·&nbsp; Leadership</p>
				<div class="hero-body">
					<div>
						<p>
							I am currently a sophomore majoring CS+EDU (Learning Science) at the University of Illinois
							at Urbana-Champaign, graduating in December 2026/May 2027. 
						</p>
						<p>
							
						</p>
						<p>
							I was originally from Shenzhen,
							China, and spent 18 years in this fast-growing city. Right now, college life provides me a
							chance to experience more.
						</p>
						</div>
					<img src="/favicon.png" alt="James Weng" class="avatar" />
				</div>
			</div>
			<div class="currently">
				<h2>Currently</h2>
				<ul>
					<li>Mentee for Vishesh Prasad in URSA, completing Mathematical Derivation Graphs Dataset</li>
					<li>Working with Professor Chris Napolitano with SEB skills</li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
