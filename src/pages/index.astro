---
import AvatarImage from '../assets/blog-placeholder-1.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={AvatarImage} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "James Weng",
			"url": "https://JamesWeng0428.github.io",
			"sameAs": [
				"https://github.com/JamesWeng0428",
				"https://www.linkedin.com/in/JamesWeng0428",
				"https://www.instagram.com/jamesweng0428/",
				"https://www.strava.com/athletes/124960807"
			],
			"jobTitle": "Student",
			"affiliation": {
				"@type": "CollegeOrUniversity",
				"name": "University of Illinois at Urbana-Champaign"
			},
			"knowsAbout": ["Computer Science", "Learning Science", "iOS Development", "Machine Learning"]
		})} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3rem 1rem;
			}
			.hero {
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 0.25rem;
			}
			.hero .subtitle {
				font-size: 1.1rem;
				color: rgb(var(--gray));
				margin: 0 0 1.5rem;
			}
			.hero-body {
				display: flex;
				gap: 2.5rem;
				align-items: flex-start;
			}
			.hero-body p {
				font-size: 1rem;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
				margin: 0;
				flex: 1;
			}
			.avatar {
				width: 200px;
				height: 200px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.section {
				margin-top: 2.5rem;
			}
			.section h2 {
				font-size: 1.2rem;
				margin: 0 0 0.75rem;
				color: rgb(var(--gray-dark));
				padding-bottom: 0.75rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.section p {
				font-size: 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
				margin: 0 0 1rem;
			}
			.section ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.section ul li {
				font-size: 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
			}
			.section ul li::before {
				content: "\2192 ";
				color: rgb(var(--accent));
			}
			.video-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-top: 1rem;
			}
			.video-grid video {
				width: 100%;
				border-radius: 8px;
			}
			.photo-gallery {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.75rem;
				margin-top: 1rem;
			}
			.photo-gallery img {
				width: 100%;
				aspect-ratio: 1;
				object-fit: cover;
				border-radius: 8px;
			}
			@media (max-width: 560px) {
				.hero-body {
					flex-direction: column-reverse;
				}
				.avatar {
					width: 120px;
					height: 120px;
				}
				.video-grid {
					grid-template-columns: 1fr;
				}
				.photo-gallery {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>James Weng</h1>
				<p class="subtitle">CS + Education @ UIUC &nbsp;·&nbsp; ENTJ &nbsp;·&nbsp; Leadership</p>
				<div class="hero-body">
					<div>
						<p>
							I am currently a sophomore majoring CS+EDU (Learning Science) at the University of Illinois
							at Urbana-Champaign, graduating in December 2026/May 2027.
						</p>
						<p>
							I was originally from Shenzhen,
							China, and spent 18 years in this fast-growing city. Right now, college life provides me a
							chance to experience more.
						</p>
						</div>
					<img src="/avatar.png" alt="James Weng" class="avatar" />
				</div>
			</div>
			<div class="section">
				<h2>Currently</h2>
				<ul>
					<li>Mentee for Vishesh Prasad in URSA, completing Mathematical Derivation Graphs Dataset</li>
					<li>Working with Professor Chris Napolitano with SEB skills</li>
				</ul>
			</div>
			<div class="section">
				<h2>Bouldering</h2>
				<p>I am not a NERD. I do sport outside from my computer. Bouldering is one of them. I am an active climber at <a href="https://www.urbanaboulders.com/" target="_blank" rel="noopener">Urbana Boulders &amp; Boneyard Boulders</a>. Here are some videos. If you are interested in climbing, you can follow my instagram account: <a href="https://www.instagram.com/jamesweng0428/" target="_blank" rel="noopener">JamesWeng0428</a></p>
				<div class="video-grid">
					<video controls playsinline preload="none">
						<source src="/bouldering-1.mp4" type="video/mp4" />
					</video>
					<video controls playsinline preload="none">
						<source src="/bouldering-2.mp4" type="video/mp4" />
					</video>
				</div>
			</div>
			<div class="section">
				<h2>Cycling</h2>
				<p>I also enjoy cycling. I have a GIANT Propel ADV SL. If you love cycling too, you can follow me on <a href="https://www.strava.com/athletes/124960807" target="_blank" rel="noopener">Strava</a></p>
				<div class="photo-gallery">
					<img src="/cycling-1.JPG" alt="Cycling photo 1" />
					<img src="/cycling-2.JPG" alt="Cycling photo 2" />
					<img src="/cycling-3.JPG" alt="Cycling photo 3" />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
