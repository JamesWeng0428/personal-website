---
import OGImage from '../assets/blog-placeholder-5.jpg';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Resume | ${SITE_TITLE}`} description="James Weng's resume — CS + Education at UIUC, software engineering and research experience." image={OGImage} />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			h1 {
				margin-bottom: 0.5rem;
			}
			.subtitle {
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			.actions {
				margin-bottom: 1.5rem;
			}
			.download-btn {
				display: inline-block;
				padding: 0.5rem 1.25rem;
				background: rgb(var(--accent));
				color: #fff;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.95rem;
				transition: opacity 0.2s;
			}
			.download-btn:hover {
				opacity: 0.85;
			}
			.pdf-container {
				width: 100%;
				border: 1px solid #e2e8f0;
				border-radius: 8px;
				overflow: hidden;
			}
			.pdf-container iframe {
				width: 100%;
				height: 80vh;
				display: block;
				border: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Resume</h1>
			<p class="subtitle">Interested in working together? Here's a quick look at my background.</p>
			<div class="actions">
				<a href="/resume.pdf" download class="download-btn">Download PDF</a>
			</div>
			<div class="pdf-container">
				<iframe src="/resume.pdf" title="James Weng Resume" />
			</div>
		</main>
		<Footer />
	</body>
</html>
