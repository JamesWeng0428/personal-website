---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import OGImage from '../../assets/blog-placeholder-about.jpg';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { fade } from 'astro:transitions';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Journals | ${SITE_TITLE}`} description="Personal journals and reflections by James Weng." image={OGImage} />
		<style>
			main {
				width: 960px;
			}
			.page-header {
				margin-bottom: var(--space-lg);
			}
			.page-header h1 {
				margin-bottom: 0.25rem;
			}
			.page-subtitle {
				color: rgb(var(--gray));
				margin: 0;
				font-size: 1rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: var(--space-md);
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 0.75rem);
			}
			ul li a {
				display: block;
				padding: var(--space-sm);
				border-radius: var(--radius-md);
				text-decoration: none;
				transition: background 0.2s, box-shadow 0.2s;
			}
			ul li a:hover {
				background: var(--surface-raised);
				box-shadow: var(--shadow-sm);
			}
			ul li img {
				margin-bottom: 0.75rem;
				border-radius: var(--radius-md);
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.1rem;
			}
			.date {
				margin: 0.25rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.excerpt {
				margin: 0.35rem 0 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				line-height: 1.5;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content" transition:animate={fade({ duration: '0.3s' })}>
			<div class="page-header">
				<h1>Journals</h1>
				<p class="page-subtitle">Personal reflections and thoughts.</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="excerpt">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
