---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About James Weng" />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2rem 1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.7;
			}
			h1 {
				margin-bottom: 0.25rem;
			}
			.tagline {
				color: rgb(var(--gray));
				margin-bottom: 2rem;
				font-size: 1rem;
			}
			section {
				margin-bottom: 2.5rem;
			}
			section h2 {
				font-size: 1.2rem;
				margin-bottom: 1rem;
				border-bottom: 1px solid #e2e8f0;
				padding-bottom: 0.4rem;
			}
			.edu-entry, .exp-entry {
				margin-bottom: 1.25rem;
			}
			.edu-entry h3, .exp-entry h3 {
				margin: 0 0 0.1rem;
				font-size: 1rem;
			}
			.meta {
				color: rgb(var(--gray));
				font-size: 0.85rem;
				margin-bottom: 0.3rem;
			}
			ul {
				margin: 0.3rem 0 0 1.2rem;
				padding: 0;
			}
			ul li {
				font-size: 0.95rem;
				margin-bottom: 0.2rem;
			}
			.skills-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.5rem 1.5rem;
				font-size: 0.95rem;
			}
			.skill-label {
				font-weight: 600;
			}
			.contact-links {
				display: flex;
				gap: 1.5rem;
				flex-wrap: wrap;
				font-size: 0.95rem;
			}
			.contact-links a {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>James Weng</h1>
			<p class="tagline">CS + Education (Learning Science) student at UIUC &nbsp;·&nbsp; Graduating Dec 2026</p>

			<section>
				<h2>About</h2>
				<p>
					I'm a computer science and learning science student at the University of Illinois at
					Urbana-Champaign. I'm drawn to problems where technology can directly help people — whether
					that's a wearable that warns my brother of a seizure, an app that turns workout data into
					actionable recovery insights, or a teaching assistant role that helps students break down
					complex problems.
				</p>
				<p>
					Outside of class and projects, I've competed in math (AIME, AMC 12 Top 1%) and programming
					(USACO Gold). I speak English, Mandarin, and Cantonese.
				</p>
			</section>

			<section>
				<h2>Education</h2>
				<div class="edu-entry">
					<h3>University of Illinois at Urbana-Champaign</h3>
					<div class="meta">B.S. Computer Science + Education (Learning Science) &nbsp;·&nbsp; GPA 3.80 &nbsp;·&nbsp; Dec 2026</div>
					<div class="meta">James Scholar &nbsp;·&nbsp; Fall 2025 – Present</div>
					<div class="meta">Relevant coursework: Software Design Studio, Data Structures, Intro to Algorithms &amp; Models of Computation</div>
				</div>
				<div class="edu-entry">
					<h3>Massachusetts Institute of Technology — Game Lab Summer School</h3>
					<div class="meta">Summer 2023</div>
					<ul>
						<li>Introduction to Time Series Modeling with Applications in Economics and Public Health</li>
					</ul>
				</div>
				<div class="edu-entry">
					<h3>Stanford University — AI4ALL Scholar</h3>
					<div class="meta">Summer 2020</div>
					<ul>
						<li>Immersed in AI through lectures, hands-on research projects, and mentoring activities</li>
						<li>Small-group research projects led by CS and AI graduate students and post-docs</li>
					</ul>
				</div>
			</section>

			<section>
				<h2>Experience</h2>
				<div class="exp-entry">
					<h3>Course Assistant (CS124) — Siebel School of Computing and Data Science, UIUC</h3>
					<div class="meta">Aug 2025 – Present</div>
					<ul>
						<li>Answer student questions on daily lessons, homework, practice quizzes, and machine projects</li>
						<li>Guide students to break down complicated problems into smaller, manageable steps</li>
					</ul>
				</div>
			</section>

			<section>
				<h2>Skills</h2>
				<div class="skills-grid">
					<span class="skill-label">Languages</span>
					<span>Java, C, C++, Python, Swift</span>
					<span class="skill-label">Spoken</span>
					<span>English, Mandarin Chinese, Cantonese Chinese</span>
				</div>
			</section>

			<section>
				<h2>Contact</h2>
				<div class="contact-links">
					<a href="mailto:zweng7@illinois.edu">zweng7@illinois.edu</a>
					<a href="https://github.com/JamesWeng0428" target="_blank" rel="noopener">GitHub</a>
					<a href="https://www.linkedin.com/in/JamesWeng0428" target="_blank" rel="noopener">LinkedIn</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
