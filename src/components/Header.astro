---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { fade } from 'astro:transitions';
---

<a href="#main-content" class="skip-link">Skip to content</a>
<header transition:persist>
	<nav>
		<button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="3" y1="6" x2="21" y2="6" />
				<line x1="3" y1="12" x2="21" y2="12" />
				<line x1="3" y1="18" x2="21" y2="18" />
			</svg>
		</button>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/portfolio">Projects</HeaderLink>
			<HeaderLink href="/blog">Journals</HeaderLink>
			<HeaderLink href="/resume">Resume</HeaderLink>
		</div>
	</nav>
</header>
<style>
	.skip-link {
		position: absolute;
		top: -100%;
		left: 1rem;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: #fff;
		border-radius: 0 0 4px 4px;
		z-index: 200;
		text-decoration: none;
		font-size: 0.9rem;
	}
	.skip-link:focus {
		top: 0;
	}
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: transform 0.3s ease;
	}
	header.header-hidden {
		transform: translateY(-100%);
	}
	@media (prefers-color-scheme: dark) {
		header {
			background: #1a1a2e;
		}
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 480px) {
		.menu-toggle {
			display: block;
		}
		.internal-links {
			display: none;
			flex-direction: column;
			width: 100%;
			position: absolute;
			top: 100%;
			left: 0;
			background: white;
			box-shadow: 0 4px 12px rgba(var(--black), 10%);
			z-index: 100;
		}
		@media (prefers-color-scheme: dark) {
			.internal-links {
				background: #1a1a2e;
			}
		}
		.internal-links.open {
			display: flex;
		}
		.internal-links a {
			padding: 0.75em 1.5em;
			border-bottom: none;
		}
		nav {
			position: relative;
			flex-wrap: wrap;
		}
	}
</style>
<script>
	document.addEventListener('astro:page-load', () => {
		const toggle = document.querySelector('.menu-toggle');
		const links = document.querySelector('.internal-links');
		if (toggle && links) {
			toggle.addEventListener('click', () => {
				const isOpen = links.classList.toggle('open');
				toggle.setAttribute('aria-expanded', String(isOpen));
			});
		}

		// Scroll-aware header show/hide
		const header = document.querySelector('header');
		if (!header) return;
		let lastScrollY = window.scrollY;
		const threshold = 60; // px before hiding kicks in

		window.addEventListener('scroll', () => {
			const currentScrollY = window.scrollY;
			if (currentScrollY > threshold && currentScrollY > lastScrollY) {
				header.classList.add('header-hidden');
			} else {
				header.classList.remove('header-hidden');
			}
			lastScrollY = currentScrollY;
		}, { passive: true });
	});
</script>
