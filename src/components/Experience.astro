---
import SectionHead from './SectionHead.astro';

const experience = [
	{
		years: '2024 — Now',
		role: 'Software Engineer',
		co: 'Current Company',
		coNote: 'Full-time',
		loc: 'New York, NY',
		detail:
			'Building backend systems and internal tooling. Shipping reliable services, chasing performance, and mentoring interns when I can.',
		stack: ['Go', 'TypeScript', 'Postgres', 'AWS'],
	},
	{
		years: '2023',
		role: 'Software Engineering Intern',
		co: 'Previous Company',
		coNote: 'Summer',
		loc: 'Remote',
		detail:
			'Worked on the platform team. Cut p99 latency on a hot-path service by ~38% and wrote the migration runbook.',
		stack: ['Python', 'Redis', 'Kubernetes'],
	},
	{
		years: '2020 — 2024',
		role: 'B.S. Computer Science',
		co: 'University',
		coNote: 'Undergraduate',
		loc: "Dean's List · GPA 3.8",
		detail:
			'Focus on distributed systems and programming languages. Research assistant in the PL lab, teaching assistant for data structures.',
		stack: ['Research', 'Teaching'],
	},
];
---

<section id="work">
	<div class="wrap">
		<SectionHead num="§ 03 / Work" title="Where I've" titleEm="built things." />
		<div class="exp">
			{
				experience.map((e) => (
					<div class="exp-row">
						<span class="years">{e.years}</span>
						<div class="body">
							<div class="role">{e.role}</div>
							<div class="co">
								{e.co} <em>· {e.coNote}</em>
							</div>
							<p class="exp-detail">{e.detail}</p>
							<div class="exp-stack">
								{e.stack.map((s) => (
									<span>{s}</span>
								))}
							</div>
						</div>
						<span class="loc">{e.loc}</span>
					</div>
				))
			}
		</div>
	</div>
</section>
