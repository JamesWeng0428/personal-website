---
import SectionHead from './SectionHead.astro';

const boulderingMedia = [
	{ type: 'video', src: '/bouldering-1.mp4', poster: '/bouldering-1-poster.jpg' },
	{ type: 'video', src: '/bouldering-2.mp4', poster: '/bouldering-2-poster.jpg' },
];

const cyclingMedia = [
	{ type: 'image', src: '/cycling-1.JPG', alt: 'Cycling — ride 1' },
	{ type: 'image', src: '/cycling-2.JPG', alt: 'Cycling — ride 2' },
	{ type: 'image', src: '/cycling-3.JPG', alt: 'Cycling — ride 3' },
];
---

<section id="hobbies">
	<div class="wrap">
		<SectionHead num="§ 02 / Hobbies" title="Off the" titleEm="keyboard." />

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">Bouldering</h3>
				<span class="hobby-label">V-grade puzzles</span>
			</div>
			<p class="hobby-desc">
				I climb at <a
					href="https://www.urbanaboulders.com/"
					target="_blank"
					rel="noopener noreferrer">Urbana Boulders</a
				>
				and Boneyard. I climb for the puzzle more than the grade — a good sequence feels the same as a
				clean proof. Follow along on
				<a href="https://www.instagram.com/jamesweng0428/" target="_blank" rel="noopener noreferrer"
					>Instagram</a
				>.
			</p>
			<div class="gallery gallery-videos">
				{
					boulderingMedia.map((m) => (
						<div class="gallery-item gallery-video">
							<video controls playsinline preload="none" poster={m.poster}>
								<source src={m.src} type="video/mp4" />
							</video>
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				<span>Gym · <b>Urbana Boulders</b></span>
				<span>Also · <b>Boneyard</b></span>
				<span>Style · <b>Problem solver</b></span>
			</div>
		</div>

		<div class="hobby-block">
			<div class="hobby-head">
				<h3 class="hobby-title">Cycling</h3>
				<span class="hobby-label">On the road</span>
			</div>
			<p class="hobby-desc">
				Long rides around Urbana on a GIANT Propel ADV SL. If you ride too, find me on <a
					href="https://www.strava.com/athletes/124960807"
					target="_blank"
					rel="noopener noreferrer">Strava</a
				>.
			</p>
			<div class="gallery gallery-photos">
				{
					cyclingMedia.map((m) => (
						<div class="gallery-item gallery-photo">
							<img src={m.src} alt={m.alt} loading="lazy" />
						</div>
					))
				}
			</div>
			<div class="hobby-stats">
				<span>Rig · <b>GIANT Propel ADV SL</b></span>
				<span>Terrain · <b>Road</b></span>
				<span>Track · <b>Strava</b></span>
			</div>
		</div>
	</div>
</section>

<style>
	.hobby-block {
		display: grid;
		gap: 1rem;
		padding: 2rem 0;
		border-bottom: 1px solid var(--rule-soft);
	}
	.hobby-block:last-of-type {
		border-bottom: none;
	}
	.hobby-block .hobby-head {
		border-top: none;
		padding-top: 0;
	}
	.hobby-block .hobby-title {
		padding-top: 0;
	}
	.hobby-block .hobby-label {
		padding-top: 0.4rem;
	}

	.gallery {
		display: grid;
		gap: 1rem;
	}
	.gallery-videos {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}
	.gallery-photos {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gallery-item {
		border: 1px solid var(--rule);
		border-radius: 4px;
		overflow: hidden;
		background: var(--bg-raised);
	}
	.gallery-video {
		aspect-ratio: 9 / 16;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.gallery-video video {
		width: 100%;
		height: 100%;
		object-fit: contain;
		background: oklch(0% 0 0);
		display: block;
	}
	.gallery-photo {
		aspect-ratio: 4 / 3;
	}
	.gallery-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	@media (max-width: 680px) {
		.gallery-videos,
		.gallery-photos {
			grid-template-columns: 1fr;
		}
	}
</style>
