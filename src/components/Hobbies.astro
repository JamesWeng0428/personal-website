---
import SectionHead from './SectionHead.astro';

const hobbies = [
	{
		title: 'Cycling',
		label: 'On the road',
		tag: 'photo',
		desc: 'Long routes out of the city — Hudson Valley loops, the Palisades, and the occasional century ride when the weather cooperates.',
		stats: [
			['Miles / yr', '~2,400'],
			['Longest', '112 mi'],
			['Rig', 'Steel road bike'],
		],
		placeholder: 'cycling photo',
	},
	{
		title: 'Bouldering',
		label: 'V-grade chaos',
		tag: 'video',
		desc: 'Falling off problems I have no business attempting. I climb for the puzzle more than the grade — a good sequence is the same feeling as a clean proof.',
		stats: [
			['Project', 'V5'],
			['Gym', 'BKB Gowanus'],
			['Outdoor', 'The Gunks'],
		],
		placeholder: 'bouldering clip',
	},
];
---

<section id="hobbies">
	<div class="wrap">
		<SectionHead num="§ 02 / Hobbies" title="Off the" titleEm="keyboard." />
		<div class="hobbies">
			{
				hobbies.map((h) => (
					<div class="hobby">
						<div class="hobby-media">
							<span class="media-tag">{h.tag}</span>[ {h.placeholder} ]
						</div>
						<div class="hobby-head">
							<h3 class="hobby-title">{h.title}</h3>
							<span class="hobby-label">{h.label}</span>
						</div>
						<p class="hobby-desc">{h.desc}</p>
						<div class="hobby-stats">
							{h.stats.map(([k, v]) => (
								<span>
									{k} · <b>{v}</b>
								</span>
							))}
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
