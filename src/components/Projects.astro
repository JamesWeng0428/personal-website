---
import SectionHead from './SectionHead.astro';

const projects = [
	{
		title: 'Project One',
		year: '2025',
		desc: 'A real-time collaboration tool for small teams. Handles 10k+ concurrent sessions on a single node.',
		tags: ['Go', 'WebSockets', 'React'],
		placeholder: 'product shot',
	},
	{
		title: 'Project Two',
		year: '2024',
		desc: 'Open-source CLI for managing Postgres migrations across monorepos. ~400 stars, used in prod at a handful of startups.',
		tags: ['Rust', 'Postgres', 'CLI'],
		placeholder: 'terminal demo',
	},
	{
		title: 'Project Three',
		year: '2024',
		desc: 'A small static-site generator I use for this very site. Fast rebuilds, MDX, zero client JS by default.',
		tags: ['TypeScript', 'Astro'],
		placeholder: 'screenshot',
	},
	{
		title: 'Project Four',
		year: '2023',
		desc: 'Weekend project: a keyboard-driven markdown editor with vim bindings and live preview.',
		tags: ['Electron', 'CodeMirror'],
		placeholder: 'editor UI',
	},
];
---

<section id="projects">
	<div class="wrap">
		<SectionHead num="§ 04 / Projects" title="Selected" titleEm="work." />
		<div class="projects">
			{
				projects.map((p) => (
					<article class="project">
						<div class="project-placeholder">[ {p.placeholder} ]</div>
						<div class="project-head">
							<h3 class="project-title">{p.title}</h3>
							<span class="project-year">{p.year}</span>
						</div>
						<p class="project-desc">{p.desc}</p>
						<div class="project-tags">
							{p.tags.map((t) => (
								<span>{t}</span>
							))}
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
