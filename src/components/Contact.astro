---
const contacts = [
	{ k: 'Email', v: 'james@example.com', href: 'mailto:james@example.com' },
	{ k: 'GitHub', v: 'JamesWeng0428', href: 'https://github.com/JamesWeng0428' },
	{ k: 'LinkedIn', v: 'in/jamesweng', href: '#' },
	{ k: 'Resume', v: 'Download PDF', href: '#' },
];
---

<section id="contact" style="border-bottom: none;">
	<div class="wrap contact">
		<div class="contact-inner">
			<h2 class="contact-headline">Let's <em>talk.</em></h2>
			<div class="contact-links">
				{
					contacts.map((c) => (
						<a class="contact-link" href={c.href}>
							<span class="k">{c.k}</span>
							<span class="v">{c.v}</span>
							<span class="arr">↗</span>
						</a>
					))
				}
			</div>
		</div>
		<footer>
			<span>© James Weng · 2026</span>
			<span>Built from scratch · No trackers</span>
		</footer>
	</div>
</section>
