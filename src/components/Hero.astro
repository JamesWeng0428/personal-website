---
// src/components/Hero.astro
// Default hero variant is "editorial". Change data-hero on <html> via Tweaks
// or by editing TWEAK_DEFAULTS in Tweaks.astro to switch variants.
---

<!-- Editorial (default) -->
<div class="wrap hero" data-hero-variant="editorial">
	<div class="fade-up">
		<span class="eyebrow">James Weng · Software Engineer</span>
	</div>
	<h1 class="hero-display fade-up d1">
		Engineer by craft,<br />
		<em>writer by habit.</em>
	</h1>
	<p class="hero-lede fade-up d2">
		I build backend systems and ship reliable software. I also write short essays about growth,
		responsibility, and the strange business of becoming an adult. Currently open to new roles.
	</p>
	<div class="fade-up d3" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
		<a class="btn" href="#contact">
			Get in touch <span class="btn-arrow">→</span>
		</a>
		<a class="btn btn-ghost" href="#work">See my work</a>
	</div>
	<div class="hero-meta fade-up d4" style="margin-top: 3.5rem;">
		<div class="hero-meta-item">
			<span class="k">Based in</span>
			<span class="v">New York, NY</span>
		</div>
		<div class="hero-meta-item">
			<span class="k">Focus</span>
			<span class="v">Backend · Distributed systems</span>
		</div>
		<div class="hero-meta-item">
			<span class="k">Status</span>
			<span class="v">Open to new roles — 2026</span>
		</div>
	</div>
</div>
