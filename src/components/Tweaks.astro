---
// Tweaks panel — optional. Delete this file if you don't want the in-design
// controls. Kept as a small inline script; no React needed.
---

<div id="tweaks" class="tweaks">
	<div class="tweaks-head">
		<h3>Tweaks</h3>
		<button class="close" type="button" data-close>CLOSE</button>
	</div>

	<div class="tweak-row">
		<label>Hero</label>
		<div class="chip-row" data-group="hero">
			<button class="chip" data-val="editorial">editorial</button>
			<button class="chip" data-val="stack">stack</button>
			<button class="chip" data-val="index">index</button>
		</div>
	</div>

	<div class="tweak-row">
		<label>Palette</label>
		<div class="swatch-row" data-group="palette">
			<div
				class="swatch"
				data-val="paper"
				title="paper"
				style="background: linear-gradient(135deg, oklch(97.5% 0.006 80) 0 55%, oklch(20% 0.012 80) 55% 100%);"
			>
			</div>
			<div
				class="swatch"
				data-val="ink"
				title="ink"
				style="background: linear-gradient(135deg, oklch(15% 0.012 265) 0 55%, oklch(78% 0.1 235) 55% 100%);"
			>
			</div>
			<div
				class="swatch"
				data-val="sand"
				title="sand"
				style="background: linear-gradient(135deg, oklch(94% 0.018 80) 0 55%, oklch(48% 0.1 35) 55% 100%);"
			>
			</div>
		</div>
	</div>

	<div class="tweak-row">
		<label>Type</label>
		<div class="chip-row" data-group="type">
			<button class="chip" data-val="instrument">Instrument</button>
			<button class="chip" data-val="fraunces">Fraunces</button>
			<button class="chip" data-val="mono-first">Mono</button>
		</div>
	</div>

	<div class="tweak-row">
		<label>Density</label>
		<div class="chip-row" data-group="density">
			<button class="chip" data-val="compact">compact</button>
			<button class="chip" data-val="default">default</button>
			<button class="chip" data-val="airy">airy</button>
		</div>
	</div>
</div>

<script>
	const DEFAULTS = { palette: 'paper', type: 'instrument', density: 'default', hero: 'editorial' };
	const state = { ...DEFAULTS, ...JSON.parse(localStorage.getItem('tweaks') || '{}') };
	const root = document.documentElement;
	const panel = document.getElementById('tweaks');

	function apply() {
		root.dataset.palette = state.palette;
		root.dataset.type = state.type;
		root.dataset.density = state.density;
		root.dataset.hero = state.hero;
		panel.querySelectorAll('[data-group]').forEach((g) => {
			const key = g.dataset.group;
			g.querySelectorAll('[data-val]').forEach((b) => {
				b.classList.toggle('active', b.dataset.val === state[key]);
			});
		});
		localStorage.setItem('tweaks', JSON.stringify(state));
	}

	panel.addEventListener('click', (e) => {
		const t = e.target.closest('[data-val]');
		if (t) {
			const key = t.parentElement.dataset.group;
			state[key] = t.dataset.val;
			apply();
		}
		if (e.target.matches('[data-close]')) panel.classList.remove('open');
	});

	// Optional keyboard shortcut: press T to toggle the panel
	window.addEventListener('keydown', (e) => {
		if (
			e.key === 't' &&
			!e.metaKey &&
			!e.ctrlKey &&
			!e.altKey &&
			!['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName)
		) {
			panel.classList.toggle('open');
		}
	});

	apply();
</script>
